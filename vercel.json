{
  "version": 2,
  "builds": [
    {
      "src": "frontend-vercel/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend-vercel/styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "frontend-vercel/script.js",
      "use": "@vercel/static"
    },
    {
      "src": "frontend-vercel/vercel.json",
      "use": "@vercel/static"
    },
    {
      "src": "frontend-vercel/README.md",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/frontend-vercel/$1"
    }
  ],
  "functions": {},
  "regions": ["iad1"]
}